@model EvensonFamilyTreeAppsDev.Models.Person

<h1>Ancestor Details</h1>

<div class="mb-3">
    <strong>Name:</strong> @Model.Prefix @Model.FirstName @Model.LastName @Model.Suffix
</div>

<div class="mb-3">
    <strong>Gender:</strong> @Model.Gender
</div>

<div class="mb-3">
    <strong>Birth Date:</strong> @Model.BirthDate?.ToString("MM/dd/yyyy")
</div>

<div class="mb-3">
    <strong>Birth Place:</strong> @Model.BirthPlace
</div>

<div class="mb-3">
    <strong>Death Date:</strong> @Model.DeathDate?.ToString("MM/dd/yyyy")
</div>

<div class="mb-3">
    <strong>Resting Place:</strong> @Model.RestingPlace
</div>

<div class="mb-3">
    <strong>Life Description:</strong> @Model.LifeDescription
</div>

<div class="mb-3">
    <strong>Parent 1:</strong>
    @(Model.Parent1 != null ? $"{Model.Parent1.FirstName} {Model.Parent1.LastName}" : "")
</div>

<div class="mb-3">
    <strong>Parent 2:</strong>
    @(Model.Parent2 != null ? $"{Model.Parent2.FirstName} {Model.Parent2.LastName}" : "")
</div>

<p>    
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
</p>

<hr />
<h2>Partnerships</h2>

<p>
    <a asp-controller="Partnership" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-primary">
        Add Partnership
    </a>
</p>

@{
    var partnerships = ViewBag.Partnerships as List<EvensonFamilyTreeAppsDev.Models.Partnership>;
}

@if (partnerships == null || !partnerships.Any())
{
    <p>No partnerships recorded.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var partnership in partnerships)
        {
            var partner = partnership.Person1Id == Model.Id ? partnership.Person2 : partnership.Person1;

            <li class="list-group-item">
                <strong>@partnership.RelationshipType?.Name</strong><br />
                Partner:
                @(partner != null ? $"{partner.FirstName} {partner.LastName}" : "Unknown")<br />
                @partnership.StartDate?.ToString("MM/dd/yyyy") - @partnership.EndDate?.ToString("MM/dd/yyyy")<br />
                @partnership.Notes
            </li>
        }
    </ul>
}

<hr />
<h2>Occupations</h2>

<p>
    <a asp-controller="Occupation" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-primary">
        Add Occupation
    </a>
</p>

@if (Model.Occupations == null || !Model.Occupations.Any())
{
    <p>No occupations recorded.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var occupation in Model.Occupations.OrderByDescending(o => o.StartDate))
        {
            <li class="list-group-item">
                <strong>@occupation.Title</strong><br />
                @occupation.StartDate?.ToString("MM/dd/yyyy") - @occupation.EndDate?.ToString("MM/dd/yyyy")<br />
                @occupation.Notes
            </li>
        }
    </ul>
}

<hr />
<h2>Education</h2>

<p>
    <a asp-controller="Education" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-primary">
        Add Education
    </a>
</p>

@if (Model.Educations == null || !Model.Educations.Any())
{
    <p>No education recorded.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var education in Model.Educations.OrderByDescending(o => o.StartDate))
        {
            <li class="list-group-item">
                <strong>@education.SchoolAttended</strong><br />
                @education.StartDate?.ToString("MM/dd/yyyy") - @education.EndDate?.ToString("MM/dd/yyyy")<br />
                @education.Notes
            </li>
        }
    </ul>
}

<hr />
<h2>Military Service</h2>

<p>
    <a asp-controller="MilitaryService" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-primary">
        Add Military Service
    </a>
</p>

@if (Model.MilitaryServices == null || !Model.MilitaryServices.Any())
{
    <p>No military service recorded.</p>
}
else
{
    <ul class="list-group mb-3">
        @foreach (var militaryService in Model.MilitaryServices.OrderByDescending(o => o.StartDate))
        {
            <li class="list-group-item">
                <strong>@militaryService.MilitaryType?.MilitaryBranch</strong>
                @militaryService.StartDate?.ToString("MM/dd/yyyy") - @militaryService.EndDate?.ToString("MM/dd/yyyy")<br />
                @militaryService.Commendations
            </li>
        }
    </ul>
}

<hr />

<h2>User Stories</h2>

<p>
    <a asp-controller="UserStory" asp-action="Create" asp-route-personId="@Model.Id" class="btn btn-primary">
        Add Story
    </a>
</p>

@if (Model.Stories == null || !Model.Stories.Any())
{
    <p>No stories have been added yet.</p>
}
else
{
    @foreach (var story in Model.Stories.OrderByDescending(s => s.CreatedOn))
    {
        <div class="card mb-3">
            <div class="card-body">
                <p>@story.Story</p>
                <small class="text-muted">
                    Added by @story.User?.Email on @story.CreatedOn.ToLocalTime().ToString("MM/dd/yyyy h:mm tt")
                </small>
            </div>
        </div>
    }
}

<p>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</p>