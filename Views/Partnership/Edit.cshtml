@model EvensonFamilyTreeAppsDev.ViewModels.Partnership.PartnershipCreateViewModel

@{
    ViewData["Title"] = "Edit Partnership";
}

<h1>Edit Partnership</h1>

<p><strong>Person:</strong> @Model.Person1Name</p>

<form asp-action="Edit" asp-route-id="@ViewBag.PartnershipId" method="post">
    <input type="hidden" asp-for="Person1Id" />
    <input type="hidden" asp-for="Person1Name" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Person2Id" class="form-label"></label>
        <select asp-for="Person2Id" asp-items="ViewBag.Person2Id" class="form-select">
            <option value="">-- Select Partner --</option>
        </select>
        <span asp-validation-for="Person2Id" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="RelationshipTypeId" class="form-label"></label>
        <select asp-for="RelationshipTypeId" asp-items="ViewBag.RelationshipTypeId" class="form-select">
            <option value="">-- Select Relationship Type --</option>
        </select>
        <span asp-validation-for="RelationshipTypeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a asp-controller="Person" asp-action="Details" asp-route-id="@Model.Person1Id" class="btn btn-secondary">Cancel</a>
</form>