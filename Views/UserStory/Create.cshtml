@model EvensonFamilyTreeAppsDev.ViewModels.UserStory.UserStoryCreateViewModel

@{
    ViewData["Title"] = "Add Story";
}

<h1>Add Story</h1>

<p>
    <strong>Ancestor:</strong> @Model.PersonName
</p>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="PersonId" />
    <input type="hidden" asp-for="FamilyTreeId" />
    <input type="hidden" asp-for="PersonName" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Story" class="form-label"></label>
        <textarea asp-for="Story" class="form-control" rows="6"></textarea>
        <span asp-validation-for="Story" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Story</button>
    <a asp-controller="Person" asp-action="Details" asp-route-id="@Model.PersonId" class="btn btn-secondary">
        Cancel
    </a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}