@model EvensonFamilyTreeAppsDev.Models.Occupation

@{
    ViewData["Title"] = "Delete Occupation";
}

<h1>Delete Occupation</h1>

<p>Are you sure you want to delete this occupation?</p>

<div class="mb-3">
    <strong>Ancestor:</strong> @Model.Person.FirstName @Model.Person.LastName
</div>

<div class="mb-3">
    <strong>Title:</strong> @Model.Title
</div>

<div class="mb-3">
    <strong>Dates:</strong> @Model.StartDate?.ToString("MM/dd/yyyy") - @Model.EndDate?.ToString("MM/dd/yyyy")
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Person" asp-action="Details" asp-route-id="@Model.PersonId" class="btn btn-secondary">Cancel</a>
</form>