@model EvensonFamilyTreeAppsDev.ViewModels.FamilyTree.FamilyTreeIndexViewModel

@{
    ViewData["Title"] = "Family Trees";
}

<h1>Family Trees</h1>

<hr />

<h2>My Family Tree</h2>

@if (Model.OwnedTrees == null || !Model.OwnedTrees.Any())
{
    <p>You do not own any family trees yet.</p>
}
else
{
    @foreach (var tree in Model.OwnedTrees)
    {
        <div class="card mb-4">
            <div class="card-header">
                <h3 class="mb-0">@tree.FamilyName</h3>
            </div>

            <div class="card-body">
                <p>
                    <a asp-controller="AuthorizedViewer"
                       asp-action="Create"
                       asp-route-familyTreeId="@tree.Id"
                       class="btn btn-sm btn-primary">
                        Add Authorized Viewer
                    </a>
                </p>

                <h5>Authorized Viewers</h5>

                @if (tree.AuthorizedViewers == null || !tree.AuthorizedViewers.Any())
                {
                    <p>No authorized viewers yet.</p>
                }
                else
                {
                    <ul class="list-group mb-3">
                        @foreach (var viewer in tree.AuthorizedViewers)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>@viewer.User.Email</span>
                                <a asp-controller="AuthorizedViewer"
                                   asp-action="Delete"
                                   asp-route-id="@viewer.Id"
                                   class="btn btn-sm btn-danger">
                                    Remove
                                </a>
                            </li>
                        }
                    </ul>
                }

                <h5>Ancestors</h5>

                @if (tree.Members == null || !tree.Members.Any())
                {
                    <p>No ancestors found for this family tree.</p>
                }
                else
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Gender</th>
                                <th>Birth Date</th>
                                <th>Birth Place</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var person in tree.Members.OrderBy(p => p.LastName).ThenBy(p => p.FirstName))
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Person" asp-action="Details" asp-route-id="@person.Id">
                                            @($"{person.Prefix} {person.FirstName} {person.LastName} {person.Suffix}".Replace("  ", " ").Trim())
                                        </a>
                                    </td>
                                    <td>@person.Gender</td>
                                    <td>@person.BirthDate?.ToString("MM/dd/yyyy")</td>
                                    <td>@person.BirthPlace</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}

<hr />

<h2>Shared With Me</h2>

@if (Model.SharedTrees == null || !Model.SharedTrees.Any())
{
    <p>No family trees have been shared with you.</p>
}
else
{
    @foreach (var tree in Model.SharedTrees)
    {
        <div class="card mb-4 border-info">
            <div class="card-header">
                <h3 class="mb-0">@tree.FamilyName</h3>
            </div>

            <div class="card-body">
                <p>
                    <strong>Owner:</strong> @tree.Owner?.Email
                </p>

                <h5>Ancestors</h5>

                @if (tree.Members == null || !tree.Members.Any())
                {
                    <p>No ancestors found for this family tree.</p>
                }
                else
                {
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Gender</th>
                                <th>Birth Date</th>
                                <th>Birth Place</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var person in tree.Members.OrderBy(p => p.LastName).ThenBy(p => p.FirstName))
                            {
                                <tr>
                                    <td>
                                        <a asp-controller="Person" asp-action="Details" asp-route-id="@person.Id">
                                            @($"{person.Prefix} {person.FirstName} {person.LastName} {person.Suffix}".Replace("  ", " ").Trim())
                                        </a>
                                    </td>
                                    <td>@person.Gender</td>
                                    <td>@person.BirthDate?.ToString("MM/dd/yyyy")</td>
                                    <td>@person.BirthPlace</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}