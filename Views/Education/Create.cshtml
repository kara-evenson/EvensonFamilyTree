@model EvensonFamilyTreeAppsDev.ViewModels.Education.EducationCreateViewModel

@{
    ViewData["Title"] = "Add Military Service";
}

<h1>Add Military Service</h1>

<p><strong>Ancestor:</strong> @Model.PersonName</p>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="PersonId" />
    <input type="hidden" asp-for="PersonName" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="EducationLevel" class="form-label"></label>
        <select asp-for="EducationLevel" asp-items="Html.GetEnumSelectList<EducationLevel>()" class="form-select">
            <option value="">-- Select Education Level --</option>
        </select>
        <span asp-validation-for="EducationLevel" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SchoolAttended" class="form-label"></label>
        <textarea asp-for="SchoolAttended" class="form-control" rows="4"></textarea>
        <span asp-validation-for="SchoolAttended" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save Education</button>
    <a asp-controller="Person" asp-action="Details" asp-route-id="@Model.PersonId" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}