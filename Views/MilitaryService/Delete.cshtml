@model EvensonFamilyTreeAppsDev.Models.MilitaryService

@{
    ViewData["Title"] = "Delete Military Service";
}

<h1>Delete Military Service</h1>

<p>Are you sure you want to delete this military service record?</p>

<div class="mb-3">
    <strong>Ancestor:</strong> @Model.Person.FirstName @Model.Person.LastName
</div>

<div class="mb-3">
    <strong>Branch:</strong> @Model.MilitaryType?.MilitaryBranch
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-controller="Person" asp-action="Details" asp-route-id="@Model.PersonId" class="btn btn-secondary">Cancel</a>
</form>